{
  "openapi": "3.0.3",
  "info": {
    "title": "NotesFlow Multi-Tenant API",
    "version": "1.0.0",
    "description": "Enterprise SaaS API for tenant-scoped notes, users, activity, analytics, profile management, and tenant lifecycle operations."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current deployment"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string" }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "type": "object" }
        }
      },
      "Tenant": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "slug": { "type": "string" },
          "name": { "type": "string" },
          "plan": { "type": "string", "enum": ["free", "pro"] }
        }
      },
      "AuthUser": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "role": { "type": "string", "enum": ["user", "admin", "superadmin"] },
          "tenant": { "$ref": "#/components/schemas/Tenant" }
        }
      },
      "Note": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "content": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "users": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "email": { "type": "string", "format": "email" }
            }
          }
        }
      },
      "Activity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "action": {
            "type": "string",
            "enum": ["note.created", "note.updated", "note.deleted", "user.invited", "user.role_updated", "profile.updated"]
          },
          "entityType": { "type": "string", "enum": ["note", "user", "profile"] },
          "entityId": { "type": "string" },
          "metadata": { "type": "object" },
          "created_at": { "type": "string", "format": "date-time" },
          "actor": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "email": { "type": "string", "format": "email" },
              "name": { "type": "string" }
            }
          }
        }
      },
      "TeamMember": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "avatarUrl": { "type": "string" },
          "role": { "type": "string", "enum": ["owner", "admin", "member"] },
          "status": { "type": "string", "enum": ["active", "invited", "disabled"] },
          "invited_at": { "type": "string", "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Profile": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "avatarUrl": { "type": "string" },
          "role": { "type": "string" }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Authentication token is missing, invalid, expired, or disabled",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Forbidden": {
        "description": "The authenticated user lacks permission",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "ValidationError": {
        "description": "Request validation failed",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "NotFound": {
        "description": "Requested resource was not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/docs": {
      "get": {
        "summary": "Swagger UI",
        "responses": {
          "200": { "description": "HTML Swagger UI" }
        }
      }
    },
    "/api/docs/swagger.json": {
      "get": {
        "summary": "OpenAPI document",
        "responses": {
          "200": { "description": "OpenAPI JSON document" }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Register a user inside an existing tenant",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "tenantSlug"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 8, "maxLength": 128 },
                  "tenantSlug": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Registered user and token" },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "description": "Email is already registered" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Authenticate user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Authenticated session" },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/auth/users": {
      "post": {
        "summary": "Create a user in the authenticated tenant",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 8, "maxLength": 128 },
                  "role": { "type": "string", "enum": ["user", "admin", "superadmin"] }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created user" },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": { "description": "Email is already registered" }
        }
      }
    },
    "/api/activity": {
      "get": {
        "summary": "List tenant activity",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 25 }
          }
        ],
        "responses": {
          "200": { "description": "Tenant activity feed" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/analytics": {
      "get": {
        "summary": "Get tenant analytics",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Tenant statistics and zero-filled 14-day usage series" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/notes": {
      "get": {
        "summary": "List tenant notes",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Tenant notes" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "summary": "Create note",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "title": { "type": "string", "minLength": 1, "maxLength": 160 },
                  "content": { "type": "string", "maxLength": 10000 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created note" },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/notes/{id}": {
      "get": {
        "summary": "Get one tenant note",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Tenant note" },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "summary": "Update one tenant note",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "title": { "type": "string", "minLength": 1, "maxLength": 160 },
                  "content": { "type": "string", "maxLength": 10000 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated note" },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "summary": "Delete one tenant note",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Deleted note" },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/profile": {
      "get": {
        "summary": "Get current profile",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Current profile" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "summary": "Update current profile",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "maxLength": 120 },
                  "avatarUrl": {
                    "type": "string",
                    "description": "Data URL for png, jpeg, or webp only. Decoded payload must be 1MB or smaller."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated profile" },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/team": {
      "get": {
        "summary": "List team members",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Tenant team members" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/team/invite": {
      "post": {
        "summary": "Invite team member with a generated temporary password",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "name": { "type": "string", "maxLength": 120 },
                  "role": { "type": "string", "enum": ["owner", "admin", "member"], "default": "member" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Invited member and generated temporary password" },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": { "description": "Email is already registered" }
        }
      }
    },
    "/api/team/{id}/role": {
      "patch": {
        "summary": "Update a team member role",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["role"],
                "properties": {
                  "role": { "type": "string", "enum": ["owner", "admin", "member"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated team member" },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/tenants": {
      "post": {
        "summary": "Create tenant",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "slug"],
                "properties": {
                  "name": { "type": "string", "minLength": 2, "maxLength": 120 },
                  "slug": { "type": "string", "minLength": 2, "maxLength": 80 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created tenant" },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "409": { "description": "Tenant already exists" }
        }
      }
    },
    "/api/tenants/{slug}/upgrade": {
      "post": {
        "summary": "Upgrade authenticated tenant to pro",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Tenant upgraded" },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  }
}
